{
	"name": "@termbridge/sandbox-cloudflare",
	"version": "0.1.0",
	"type": "module",
	"license": "MIT",
	"description": "Cloudflare SandboxProvider for termbridge — env:\"sandbox\" via Cloudflare (injectable client; no SDK required for unit tests)",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check ."
	},
	"dependencies": {
		"@termbridge/core": "workspace:*"
	}
}
