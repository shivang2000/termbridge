# termbridge — local secrets (copy to .env and fill in)
# .env is gitignored. Never commit real keys.

# --- E2B (live sandbox smoke proven) ---
# Dashboard: https://e2b.dev  →  https://e2b.dev/dashboard
# Docs: https://e2b.dev/docs
E2B_API_KEY=

# --- Daytona ---
# Site: https://www.daytona.io
# Dashboard / API keys: https://app.daytona.io  (or https://daytona.io/dashboard)
# Docs: https://www.daytona.io/docs
DAYTONA_API_KEY=
# Optional API base if self-hosted
# DAYTONA_API_URL=

# --- Cloudflare Containers (requires Workers Paid plan) ---
# Create token: https://dash.cloudflare.com/profile/api-tokens
# Template: "Edit Cloudflare Workers" (defaults are fine)
# After upgrade, if image push 401s, add Custom permission:
#   Account → Cloudchamber → Edit  (Containers registry / deploy)
# Account ID: dash.cloudflare.com/<ACCOUNT_ID>/…
# Containers: https://developers.cloudflare.com/containers/
# Upgrade: https://dash.cloudflare.com/?to=/:account/workers/plans
#
# Deploy control Worker once (Docker required):
#   bun --env-file=.env scripts/deploy-cloudflare-sandbox.ts
# Then set:
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_SANDBOX_WORKER_URL=https://termbridge-sandbox.<subdomain>.workers.dev
# CLOUDFLARE_CONTROL_TOKEN=   # optional dedicated secret; defaults to API token

# --- Optional termbridge server ---
# TERMBRIDGE_TOKEN=
# TERMBRIDGE_MAX_SESSIONS=4
# TERMBRIDGE_ALLOWED_ENVS=local,docker,sandbox
# PORT=8787
# HOST=127.0.0.1
